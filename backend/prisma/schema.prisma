// Geo-Franchise Marketplace — Complete Prisma Schema
// Primary Market: Pakistan (PKR, Urdu+English, +92)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// MODULE A — COUNTRY & REGION
// ═══════════════════════════════════════════════════════════

model Country {
  id                String      @id           // ISO 3166-1 alpha-2: "PK"
  name              String
  nativeName        String
  phoneCode         String                    // "+92"
  phoneFormat       String                    // "3XX-XXXXXXX"
  defaultCurrencyId String
  defaultCurrency   Currency    @relation("CountryDefaultCurrency", fields: [defaultCurrencyId], references: [id])
  defaultLanguageId String
  defaultLanguage   Language    @relation("CountryDefaultLanguage", fields: [defaultLanguageId], references: [id])
  timezone          String                    // "Asia/Karachi"
  isActive          Boolean     @default(true)
  isDefault         Boolean     @default(false)
  geoZones          GeoZone[]
  supportedCurrencies CountryCurrency[]
  supportedLanguages  CountryLanguage[]
  paymentGateways   CountryPaymentGateway[]
  subscriptionPlans SubscriptionPlan[]
  users             User[]      @relation("UserCountry")
  listings          Listing[]   @relation("ListingCountry")
  createdAt         DateTime    @default(now())
}

// ═══════════════════════════════════════════════════════════
// MODULE B — CURRENCY
// ═══════════════════════════════════════════════════════════

model Currency {
  id              String    @id           // ISO 4217: "PKR"
  name            String
  nativeName      String
  symbol          String                  // "₨"
  symbolNative    String
  symbolPosition  SymbolPosition @default(PREFIX)
  decimalDigits   Int       @default(2)
  rounding        Float     @default(0)
  isActive        Boolean   @default(true)
  isDefault       Boolean   @default(false)
  exchangeRatesBase   ExchangeRate[] @relation("BaseCurrency")
  exchangeRatesTarget ExchangeRate[] @relation("TargetCurrency")
  countriesDefault Country[]  @relation("CountryDefaultCurrency")
  countryLinks    CountryCurrency[]
  listings        Listing[]  @relation("ListingCurrency")
  transactions    Transaction[]
  wallets         Wallet[]
  subscriptionPrices SubscriptionPrice[]
  priceHistory    PriceHistory[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ExchangeRate {
  id               String    @id @default(uuid())
  baseCurrencyId   String
  baseCurrency     Currency  @relation("BaseCurrency", fields: [baseCurrencyId], references: [id])
  targetCurrencyId String
  targetCurrency   Currency  @relation("TargetCurrency", fields: [targetCurrencyId], references: [id])
  rate             Decimal   @db.Decimal(18, 8)
  source           String    @default("MANUAL")
  effectiveAt      DateTime  @default(now())
  createdAt        DateTime  @default(now())

  @@unique([baseCurrencyId, targetCurrencyId])
}

model CountryCurrency {
  countryId  String
  country    Country  @relation(fields: [countryId], references: [id])
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])
  isPrimary  Boolean  @default(false)

  @@id([countryId, currencyId])
}

enum SymbolPosition {
  PREFIX
  SUFFIX
}

// ═══════════════════════════════════════════════════════════
// MODULE C — LANGUAGE & LOCALIZATION
// ═══════════════════════════════════════════════════════════

model Language {
  id            String    @id           // BCP 47: "ur", "en"
  name          String
  nativeName    String
  direction     TextDirection @default(LTR)
  isActive      Boolean   @default(true)
  isDefault     Boolean   @default(false)
  flagEmoji     String?
  countriesDefault Country[] @relation("CountryDefaultLanguage")
  countryLinks  CountryLanguage[]
  translations  Translation[]
  users         User[]    @relation("UserLanguage")
  categoryTranslations    CategoryTranslation[]
  productTypeTranslations ProductTypeTranslation[]
  attributeTranslations   AttributeTranslation[]
  optionTranslations      OptionTranslation[]
  unitTranslations        UnitTranslation[]
  createdAt     DateTime  @default(now())
}

model CountryLanguage {
  countryId  String
  country    Country  @relation(fields: [countryId], references: [id])
  languageId String
  language   Language @relation(fields: [languageId], references: [id])
  isPrimary  Boolean  @default(false)

  @@id([countryId, languageId])
}

model Translation {
  id         String   @id @default(uuid())
  languageId String
  language   Language @relation(fields: [languageId], references: [id])
  namespace  String                    // "common" | "auth" | "listings"
  key        String
  value      String
  isRTL      Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([languageId, namespace, key])
}

enum TextDirection {
  LTR
  RTL
}

// ═══════════════════════════════════════════════════════════
// MODULE D — DYNAMIC PRODUCT CATALOG
// ═══════════════════════════════════════════════════════════

model Category {
  id           String        @id @default(uuid())
  slug         String        @unique
  icon         String?
  colorHex     String?
  sortOrder    Int           @default(0)
  isActive     Boolean       @default(true)
  parentId     String?
  parent       Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryTree")
  productTypes ProductType[]
  listings     Listing[]
  translations CategoryTranslation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model CategoryTranslation {
  id          String   @id @default(uuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  languageId  String
  language    Language @relation(fields: [languageId], references: [id])
  name        String
  description String?

  @@unique([categoryId, languageId])
}

model ProductType {
  id           String                @id @default(uuid())
  slug         String                @unique
  categoryId   String
  category     Category              @relation(fields: [categoryId], references: [id])
  icon         String?
  isActive     Boolean               @default(true)
  sortOrder    Int                   @default(0)
  attributes   ProductAttribute[]
  listings     Listing[]
  translations ProductTypeTranslation[]
  priceHistory PriceHistory[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model ProductTypeTranslation {
  id            String      @id @default(uuid())
  productTypeId String
  productType   ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  languageId    String
  language      Language    @relation(fields: [languageId], references: [id])
  name          String
  description   String?
  unitLabel     String?

  @@unique([productTypeId, languageId])
}

model ProductAttribute {
  id            String                  @id @default(uuid())
  productTypeId String
  productType   ProductType             @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  slug          String
  inputType     AttributeInputType      @default(SELECT)
  isRequired    Boolean                 @default(false)
  isFilterable  Boolean                 @default(true)
  sortOrder     Int                     @default(0)
  isActive      Boolean                 @default(true)
  options       AttributeOption[]
  listingValues ListingAttributeValue[]
  translations  AttributeTranslation[]
  createdAt     DateTime                @default(now())
}

model AttributeOption {
  id          String              @id @default(uuid())
  attributeId String
  attribute   ProductAttribute    @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  slug        String
  sortOrder   Int                 @default(0)
  isActive    Boolean             @default(true)
  translations OptionTranslation[]
  listingValues ListingAttributeValue[]
}

model AttributeTranslation {
  id          String           @id @default(uuid())
  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  languageId  String
  language    Language         @relation(fields: [languageId], references: [id])
  label       String

  @@unique([attributeId, languageId])
}

model OptionTranslation {
  id         String          @id @default(uuid())
  optionId   String
  option     AttributeOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  languageId String
  language   Language        @relation(fields: [languageId], references: [id])
  label      String

  @@unique([optionId, languageId])
}

model ListingAttributeValue {
  id          String           @id @default(uuid())
  listingId   String
  listing     Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id])
  optionId    String?
  option      AttributeOption? @relation(fields: [optionId], references: [id])
  textValue   String?
  numberValue Decimal?

  @@unique([listingId, attributeId])
}

enum AttributeInputType {
  TEXT
  NUMBER
  SELECT
  MULTI_SELECT
  BOOLEAN
  DATE
}

// ═══════════════════════════════════════════════════════════
// UNITS OF MEASUREMENT
// ═══════════════════════════════════════════════════════════

model Unit {
  id               String            @id @default(uuid())
  slug             String            @unique
  type             UnitType
  isBaseUnit       Boolean           @default(false)
  conversionFactor Decimal           @db.Decimal(18, 8) @default(1)
  isActive         Boolean           @default(true)
  sortOrder        Int               @default(0)
  translations     UnitTranslation[]
  listings         Listing[]
  createdAt        DateTime          @default(now())
}

model UnitTranslation {
  id           String @id @default(uuid())
  unitId       String
  unit         Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  languageId   String
  language     Language @relation(fields: [languageId], references: [id])
  name         String
  abbreviation String

  @@unique([unitId, languageId])
}

enum UnitType {
  WEIGHT
  VOLUME
  COUNT
  LENGTH
  AREA
  OTHER
}

// ═══════════════════════════════════════════════════════════
// PRICE HISTORY
// ═══════════════════════════════════════════════════════════

model PriceHistory {
  id            String      @id @default(uuid())
  productTypeId String
  productType   ProductType @relation(fields: [productTypeId], references: [id])
  currencyId    String
  currency      Currency    @relation(fields: [currencyId], references: [id])
  minPricePaisa BigInt
  maxPricePaisa BigInt
  avgPricePaisa BigInt
  sampleCount   Int
  recordedAt    DateTime    @default(now())

  @@index([productTypeId, currencyId, recordedAt])
}

// ═══════════════════════════════════════════════════════════
// MODULE 1 — AUTHENTICATION & USERS
// ═══════════════════════════════════════════════════════════

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  phone         String?   @unique
  passwordHash  String?
  firstName     String
  lastName      String
  displayName   String?
  avatar        String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  languageId    String    @default("en")
  language      Language  @relation("UserLanguage", fields: [languageId], references: [id])
  currencyId    String    @default("PKR")
  countryId     String    @default("PK")
  country       Country   @relation("UserCountry", fields: [countryId], references: [id])
  cnicNumber    String?
  city          String?
  geoZoneId     String?
  geoZone       GeoZone?  @relation(fields: [geoZoneId], references: [id])
  latitude      Float?
  longitude     Float?
  fcmToken      String?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  lastLoginAt   DateTime?

  // ── Dealer / Pro Verification Fields ──
  accountStatus      AccountStatus @default(ACTIVE)
  businessName       String?
  businessAddress    String?
  cnicFrontImage     String?    // URL to uploaded CNIC front image (original)
  cnicBackImage      String?    // URL to uploaded CNIC back image (original)
  policeVerificationCert String? // URL to police verification certificate
  characterCertificate   String? // URL to character certificate
  dealerPhoto        String?    // URL to dealer's own photo (must match CNIC photo)
  shopPhoto          String?    // URL to shop/office photo (legacy — kept for backward compat)
  ntnNumber          String?    // Tax number
  bankName           String?
  bankAccountTitle   String?
  bankAccountNumber  String?
  kycSubmittedAt     DateTime?
  kycApprovedAt      DateTime?
  kycRejectionReason String?
  kycStep            Int        @default(0) // Current step in KYC wizard (0 = not started)

  // ── Warehouse Verification (required for dealers/franchises) ──
  warehouseAddress       String?    // Full address of existing warehouse
  warehouseInsidePhoto   String?    // URL to photo of warehouse interior
  warehouseStreetPhoto   String?    // URL to photo of street outside warehouse
  warehouseFrontDoorPhoto String?   // URL to photo of warehouse front door/entrance

  // ── SIM Ownership Verification ──
  simOwnerName           String?    // Name registered on SIM (must match CNIC)
  simVerified            Boolean    @default(false) // OTP verified on registered SIM

  // ── Criminal Record Check ──
  criminalCheckStatus    CriminalCheckStatus @default(NOT_CHECKED)
  criminalCheckNotes     String?    // Admin notes on criminal background
  criminalFlagged        Boolean    @default(false) // True = criminal activity detected, ID blocked

  // ── Deposit / Activation ──
  requiredDeposit        Int        @default(0)   // Amount in PKR required to activate
  depositPaid            Boolean    @default(false) // Whether initial deposit has been paid
  depositPaidAt          DateTime?  // When the deposit was paid
  depositAmount          Int        @default(0)   // Actual amount deposited

  listings           Listing[]         @relation("SellerListings")
  listingFavorites   ListingFavorite[]
  listingReports     ListingReport[]   @relation("ListingReporter")
  transactions  Transaction[] @relation("BuyerTransactions")
  sellerTransactions Transaction[] @relation("SellerTransactions")
  notifications Notification[]
  wallet        Wallet?
  subscription  UserSubscription?
  refreshTokens RefreshToken[]
  otps          OTP[]
  chatMessagesFrom ChatMessage[] @relation("MessageFrom")
  chatMessagesTo   ChatMessage[] @relation("MessageTo")
  dealerTerritories DealerTerritory[] @relation("DealerTerritories")
  auditLogs     AuditLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum AccountStatus {
  PENDING_VERIFICATION
  DOCUMENTS_SUBMITTED
  UNDER_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

enum CriminalCheckStatus {
  NOT_CHECKED       // Background check not yet performed
  PENDING           // Check submitted, awaiting result
  CLEARED           // No criminal record found
  FLAGGED           // Criminal activity found — account blocked
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model OTP {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String?
  email     String?
  code      String
  purpose   OTPPurpose @default(LOGIN)
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  COLLECTION_MANAGER
  REGIONAL_MANAGER
  FRANCHISE_OWNER
  DEALER
  WHOLESALE_BUYER
  CUSTOMER
}

enum OTPPurpose {
  LOGIN
  REGISTER
  RESET_PASSWORD
  TWO_FACTOR
}

// ═══════════════════════════════════════════════════════════
// MODULE 3 — GEO-ZONES
// ═══════════════════════════════════════════════════════════

model GeoZone {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  type        GeoZoneType
  parentId    String?
  parent      GeoZone?  @relation("ZoneTree", fields: [parentId], references: [id])
  children    GeoZone[] @relation("ZoneTree")
  countryId   String
  country     Country   @relation(fields: [countryId], references: [id])
  latitude    Float?
  longitude   Float?
  radiusKm    Float?
  isActive    Boolean   @default(true)
  users       User[]
  listings    Listing[]
  dealerTerritories DealerTerritory[] @relation("TerritoryZones")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum GeoZoneType {
  COUNTRY
  PROVINCE
  CITY
  LOCAL_AREA
}

// ═══════════════════════════════════════════════════════════
// LISTINGS
// ═══════════════════════════════════════════════════════════

model Listing {
  id              String                  @id @default(uuid())
  title           String
  description     String
  categoryId      String
  category        Category                @relation(fields: [categoryId], references: [id])
  productTypeId   String?
  productType     ProductType?            @relation(fields: [productTypeId], references: [id])
  attributeValues ListingAttributeValue[]
  pricePaisa      BigInt
  currencyId      String                  @default("PKR")
  currency        Currency                @relation("ListingCurrency", fields: [currencyId], references: [id])
  priceNegotiable Boolean                 @default(true)
  quantity        Decimal                 @db.Decimal(12, 3)
  unitId          String
  unit            Unit                    @relation(fields: [unitId], references: [id])
  minOrderQuantity Decimal?               @db.Decimal(12, 3)
  sellerId        String
  seller          User                    @relation("SellerListings", fields: [sellerId], references: [id])
  geoZoneId       String
  geoZone         GeoZone                 @relation(fields: [geoZoneId], references: [id])
  latitude        Float
  longitude       Float
  address         String?
  cityName        String?
  countryId       String                  @default("PK")
  country         Country                 @relation("ListingCountry", fields: [countryId], references: [id])
  contactNumber   String?
  status          ListingStatus           @default(ACTIVE)
  visibilityLevel VisibilityLevel         @default(LOCAL)
  images          ListingImage[]
  viewCount       Int                     @default(0)
  interestedCount Int                     @default(0)
  isFlagged       Boolean                 @default(false)
  flagCount       Int                     @default(0)
  escalationHistory EscalationLog[]
  favorites       ListingFavorite[]
  reports         ListingReport[]
  transactions    Transaction[]
  collections     Collection[]
  expiresAt       DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model ListingImage {
  id        String  @id @default(uuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
}

model ListingFavorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model ListingReport {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User     @relation("ListingReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reason    String
  status    String   @default("pending") // pending|reviewed|dismissed
  createdAt DateTime @default(now())

  @@unique([listingId, reporterId])
  @@index([listingId])
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PENDING_REVIEW
  ASSIGNED_TO_DEALER    // Dealer accepted, collection in progress
  COLLECTION_IN_PROGRESS
  COLLECTED             // Material picked up
  DELIVERED             // Delivered to recycling center
  SOLD
  EXPIRED
  CLOSED
  REJECTED
}

enum VisibilityLevel {
  LOCAL
  NEIGHBOR
  CITY
  PROVINCE
  NATIONAL
  PUBLIC
}

// ═══════════════════════════════════════════════════════════
// DEALER TERRITORIES
// ═══════════════════════════════════════════════════════════

model DealerTerritory {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation("DealerTerritories", fields: [userId], references: [id], onDelete: Cascade)
  geoZoneId   String
  geoZone     GeoZone   @relation("TerritoryZones", fields: [geoZoneId], references: [id])
  isExclusive Boolean   @default(true)          // No other dealer of same role at same zone
  isActive    Boolean   @default(true)
  assignedBy  String?                           // Admin who assigned it
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, geoZoneId])                 // One assignment per user per zone
  @@index([geoZoneId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════
// ESCALATION ENGINE
// ═══════════════════════════════════════════════════════════

model EscalationRule {
  id            String          @id @default(uuid())
  fromLevel     VisibilityLevel
  toLevel       VisibilityLevel
  delayHours    Int                               // Hours after listing creation (or last escalation) to escalate
  notifyRoles   Json?                             // ["DEALER","FRANCHISE_OWNER",...] - roles to notify at this level
  isActive      Boolean         @default(true)
  sortOrder     Int             @default(0)       // Order of escalation
  createdAt     DateTime        @default(now())

  @@unique([fromLevel, toLevel])
}

model EscalationLog {
  id           String          @id @default(uuid())
  listingId    String
  listing      Listing         @relation(fields: [listingId], references: [id])
  fromLevel    VisibilityLevel
  toLevel      VisibilityLevel
  reason       String?
  notifiedUserIds Json?                           // Track who was notified
  escalatedAt  DateTime        @default(now())
}

// ═══════════════════════════════════════════════════════════
// TRANSACTIONS & BONDS
// ═══════════════════════════════════════════════════════════

model Transaction {
  id                String            @id @default(uuid())
  listingId         String
  listing           Listing           @relation(fields: [listingId], references: [id])
  buyerId           String
  buyer             User              @relation("BuyerTransactions", fields: [buyerId], references: [id])
  sellerId          String
  seller            User              @relation("SellerTransactions", fields: [sellerId], references: [id])
  amountPaisa       BigInt            // legacy / agreed amount
  offeredPricePaisa BigInt?           // initial offer (paisa)
  counterPricePaisa BigInt?           // counter offer (paisa)
  finalPricePaisa   BigInt?           // agreed on accept
  totalPaisa        BigInt?           // finalPrice * quantity
  unitId            String?
  currencyId        String
  currency          Currency          @relation(fields: [currencyId], references: [id])
  quantity          Decimal           @db.Decimal(12, 3)
  status            TransactionStatus @default(OFFER_MADE)
  message           String?          // offer/counter message
  bond              Bond?
  paymentId         String?
  payment           Payment?          @relation(fields: [paymentId], references: [id])
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Bond {
  id            String   @id @default(uuid())
  transactionId String   @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  pdfUrl        String?
  signedBySeller Boolean @default(false)
  signedByBuyer  Boolean @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())
}

enum TransactionStatus {
  OFFER_MADE
  OFFERED        // alias for offer created (used by routes)
  NEGOTIATING    // counter offered
  OFFER_ACCEPTED
  ACCEPTED       // alias (used by routes)
  OFFER_REJECTED
  REJECTED       // alias (used by routes)
  BOND_CREATED
  PAYMENT_PENDING
  PAYMENT_COMPLETED
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
}

// ═══════════════════════════════════════════════════════════
// PAYMENTS
// ═══════════════════════════════════════════════════════════

model Payment {
  id           String         @id @default(uuid())
  userId       String
  gateway      PaymentGateway
  gatewayRef   String?
  amountPaisa  BigInt
  currencyId   String
  status       PaymentStatus  @default(PENDING)
  purpose      PaymentPurpose
  metadata     Json?
  transactions Transaction[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  balancePaisa BigInt  @default(0)
  currencyId  String
  currency    Currency @relation(fields: [currencyId], references: [id])
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model CountryPaymentGateway {
  id          String         @id @default(uuid())
  countryId   String
  country     Country        @relation(fields: [countryId], references: [id])
  gateway     PaymentGateway
  isActive    Boolean        @default(true)
  config      Json?
  displayName String
  logoUrl     String?
  sortOrder   Int            @default(0)
}

enum PaymentGateway {
  JAZZCASH
  EASYPAISA
  STRIPE
  RAZORPAY
  BANK_TRANSFER
  WALLET
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentPurpose {
  SUBSCRIPTION
  TRANSACTION
  WALLET_TOPUP
}

// ═══════════════════════════════════════════════════════════
// SUBSCRIPTIONS
// ═══════════════════════════════════════════════════════════

model SubscriptionPlan {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  description String?
  features    Json?
  maxListings Int                @default(10)
  maxZones    Int                @default(1)
  isActive    Boolean            @default(true)
  countryId   String
  country     Country            @relation(fields: [countryId], references: [id])
  prices      SubscriptionPrice[]
  userSubs    UserSubscription[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model SubscriptionPrice {
  id        String           @id @default(uuid())
  planId    String
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  currencyId String
  currency  Currency         @relation(fields: [currencyId], references: [id])
  pricePaisa BigInt
  interval  BillingInterval  @default(MONTHLY)

  @@unique([planId, currencyId, interval])
}

model UserSubscription {
  id        String           @id @default(uuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id])
  planId    String
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  status    SubscriptionStatus @default(ACTIVE)
  startedAt DateTime         @default(now())
  expiresAt DateTime
  createdAt DateTime         @default(now())
}

enum BillingInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  GRACE_PERIOD
}

// ═══════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

enum NotificationType {
  NEW_LISTING
  OFFER_RECEIVED
  OFFER_ACCEPTED
  OFFER_REJECTED
  PAYMENT_RECEIVED
  PAYMENT_SENT
  ESCALATION
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_EXPIRED
  SYSTEM
  CHAT_MESSAGE
}

// ═══════════════════════════════════════════════════════════
// CHAT
// ═══════════════════════════════════════════════════════════

model ChatMessage {
  id          String        @id @default(uuid())
  fromUserId  String
  fromUser    User          @relation("MessageFrom", fields: [fromUserId], references: [id])
  toUserId    String
  toUser      User          @relation("MessageTo", fields: [toUserId], references: [id])
  message     String
  isRead      Boolean       @default(false)
  status      MessageStatus @default(SENT)
  clientMsgId String?       // Client-side UUID for deduplication
  createdAt   DateTime      @default(now())
  deliveredAt DateTime?
  readAt      DateTime?

  @@unique([clientMsgId])
  @@index([fromUserId, toUserId, createdAt])
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ═══════════════════════════════════════════════════════════
// PLATFORM CONFIG
// ═══════════════════════════════════════════════════════════

model PlatformConfig {
  id    String @id
  key   String @unique
  value String
  label String?
}

// ═══════════════════════════════════════════════════════════
// AUDIT LOGS
// ═══════════════════════════════════════════════════════════

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
}

// ═══════════════════════════════════════════════════════════
// COLLECTION TRACKING — Core Revenue & Carbon Credit Engine
// ═══════════════════════════════════════════════════════════
//
// FLOW:
// 1. Customer posts listing (scrap with location)
// 2. Dealer sees it, taps "Accept & Collect" → Collection record created
// 3. Dealer travels to location
// 4. Dealer arrives → GPS verified (within 200m of listing location)
// 5. Dealer collects → takes photos, confirms weight
// 6. Dealer marks "COLLECTED" → GPS verified again
// 7. Dealer marks "DELIVERED_TO_CENTER" → final status
//
// If dealer does NOT update status within deadline:
//   → Rating drops
//   → Listing escalates to adjacent dealer
//   → Current dealer gets penalty
//
// All data feeds into carbon credit analytics:
//   → Weight by category × area × time → volume prediction
//   → Collection points mapped → efficiency metrics
//   → Carbon offset calculation per KG per material type

model Collection {
  id                String            @id @default(uuid())

  // ── Linked entities ──
  listingId         String
  listing           Listing           @relation(fields: [listingId], references: [id])
  transactionId     String?
  dealerId          String            // The dealer/franchise who accepted collection
  customerId        String            // The customer who posted the listing

  // ── Status tracking ──
  status            CollectionStatus  @default(ASSIGNED)
  assignedAt        DateTime          @default(now())
  acceptedAt        DateTime?         // Dealer tapped "Accept"
  enRouteAt         DateTime?         // Dealer started traveling
  arrivedAt         DateTime?         // GPS confirmed: dealer at location
  collectedAt       DateTime?         // Material picked up, photos taken
  deliveredAt       DateTime?         // Delivered to recycling center
  cancelledAt       DateTime?
  cancelReason      String?

  // ── GPS Verification ──
  listingLat        Float             // Expected pickup latitude
  listingLng        Float             // Expected pickup longitude
  dealerAcceptLat   Float?            // GPS when dealer accepted
  dealerAcceptLng   Float?
  dealerArriveLat   Float?            // GPS when dealer arrived at location
  dealerArriveLng   Float?
  dealerCollectLat  Float?            // GPS when marking "collected"
  dealerCollectLng  Float?
  dealerDeliverLat  Float?            // GPS at recycling center
  dealerDeliverLng  Float?
  gpsVerified       Boolean           @default(false) // True if arrival GPS < 200m from listing

  // ── Material verification ──
  confirmedWeightKg Decimal?          @db.Decimal(12, 3) // Actual weight at collection
  categoryId        String            // Material category
  photoUrls         Json?             // Array of photo URLs taken at collection
  qualityRating     Int?              // 1-5 material quality rated by dealer
  notes             String?

  // ── Time tracking (for ratings) ──
  deadlineAt        DateTime          // Must update status by this time or escalate
  responseTimeMin   Int?              // Minutes from assignment to acceptance
  collectionTimeMin Int?              // Minutes from acceptance to collection
  totalTimeMin      Int?              // Total minutes from assignment to delivery

  // ── Carbon credit data ──
  carbonOffsetKg    Decimal?          @db.Decimal(12, 4) // Calculated CO2 offset
  geoZoneId         String?           // Area where collected
  cityName          String?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([dealerId, status])
  @@index([listingId])
  @@index([categoryId, geoZoneId])
  @@index([status, deadlineAt])
  @@index([collectedAt])
}

enum CollectionStatus {
  ASSIGNED            // Admin/system assigned to dealer
  ACCEPTED            // Dealer tapped "Accept"
  EN_ROUTE            // Dealer is traveling to location
  ARRIVED             // GPS confirmed dealer at location
  COLLECTED           // Material picked up, photos taken
  DELIVERED_TO_CENTER // Delivered to recycling/processing center
  CANCELLED           // Dealer cancelled or reassigned
  ESCALATED           // Deadline passed, moved to next dealer
  EXPIRED             // No dealer accepted in time
}

// ═══════════════════════════════════════════════════════════
// DEALER RATINGS — Calculated from collection performance
// ═══════════════════════════════════════════════════════════
//
// Rating is calculated based on:
//   1. Response Time (how fast dealer accepts) — 30% weight
//   2. Collection Time (how fast dealer collects) — 30% weight
//   3. Status Update Compliance (did they update on time) — 25% weight
//   4. Customer Feedback — 15% weight
//
// Ratings affect:
//   - Priority for new listing assignments
//   - Visibility in search results
//   - Eligibility for premium territories
//   - Escalation priority (low-rated dealers get listings last)

model DealerRating {
  id              String   @id @default(uuid())
  dealerId        String
  collectionId    String?  // Linked to specific collection event
  customerId      String?  // Customer who gave feedback

  // ── Score breakdown (1-5 scale) ──
  responseScore   Decimal  @db.Decimal(3, 2) // Based on response time
  collectionScore Decimal  @db.Decimal(3, 2) // Based on collection speed
  complianceScore Decimal  @db.Decimal(3, 2) // Based on status update timeliness
  customerScore   Decimal? @db.Decimal(3, 2) // Customer rating (optional)
  overallScore    Decimal  @db.Decimal(3, 2) // Weighted average

  // ── Raw data ──
  responseTimeMin   Int?
  collectionTimeMin Int?
  statusUpdatedOnTime Boolean @default(true)
  customerFeedback  String?
  period            String   // "2026-03" → monthly aggregation key

  createdAt DateTime @default(now())

  @@index([dealerId, period])
  @@index([dealerId, overallScore])
}

// ═══════════════════════════════════════════════════════════
// CARBON CREDIT ANALYTICS
// ═══════════════════════════════════════════════════════════
//
// Aggregated data per category × area × period for:
//   - Volume prediction (trending analysis)
//   - Carbon credit calculation
//   - Funding proposals (how much CO2 offset)
//   - Collection point density mapping
//
// Carbon offset factors (kg CO2 saved per kg material):
//   Metals     → 4.0 kg CO2/kg
//   Plastics   → 1.5 kg CO2/kg
//   Paper      → 1.1 kg CO2/kg
//   Electronics → 2.5 kg CO2/kg
//   Glass      → 0.3 kg CO2/kg
//   Organic    → 0.5 kg CO2/kg

model CarbonCreditRecord {
  id              String   @id @default(uuid())

  // ── Dimensions ──
  categoryId      String               // Material category
  geoZoneId       String               // Area
  cityName        String
  period          String               // "2026-03" or "2026-W10"

  // ── Volume data ──
  totalListings   Int      @default(0) // Number of listings posted
  totalCollected  Int      @default(0) // Number successfully collected
  totalWeightKg   Decimal  @default(0) @db.Decimal(14, 3) // Total weight collected
  avgWeightKg     Decimal  @default(0) @db.Decimal(12, 3)
  avgPricePkrKg   Decimal  @default(0) @db.Decimal(10, 2) // Average price per kg

  // ── Carbon credit ──
  carbonOffsetKg  Decimal  @default(0) @db.Decimal(14, 4) // Total CO2 offset
  carbonCreditValue Decimal @default(0) @db.Decimal(12, 2) // Estimated value in PKR

  // ── Collection efficiency ──
  avgResponseTimeMin   Int?
  avgCollectionTimeMin Int?
  onTimeCollectionRate Decimal? @db.Decimal(5, 2) // % collected before deadline
  escalationRate       Decimal? @db.Decimal(5, 2) // % that escalated

  // ── Collection points (for mapping) ──
  collectionPoints Json?   // Array of {lat, lng, weight, date}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, geoZoneId, period])
  @@index([period])
  @@index([geoZoneId, period])
  @@index([categoryId, period])
}

// ═══════════════════════════════════════════════════════════
// COLLECTION POINT REGISTRY
// ═══════════════════════════════════════════════════════════
// Physical locations where dealers deliver collected materials
// Used for route optimization and carbon credit verification

model CollectionCenter {
  id          String   @id @default(uuid())
  name        String
  address     String
  cityName    String
  geoZoneId   String?
  latitude    Float
  longitude   Float
  operatorId  String?  // User who manages this center
  capacity    String?  // e.g. "500 kg/day"
  materials   Json?    // Accepted material categories
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
